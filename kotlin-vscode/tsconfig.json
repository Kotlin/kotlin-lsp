{
  "compilerOptions": {
    "paths": {
      "@keyHandlerUtils": [
        "./src/keyHandlerUtils"
      ],
      "@keyHandlerTestUtils": [
        "./src/keyHandlerTestUtils"
      ]
    },
    "module": "commonjs",
    "target": "es2020",
    "strict": true,
    "lib": [
      "es2020"
    ],
    "outDir": "out/compile",
    "rootDir": "src",
    "sourceMap": true,
    "composite": true,
    "tsBuildInfoFile": "out/compile/tsconfig.tsbuildinfo",
    "esModuleInterop": true,
    "preserveSymlinks": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
