{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "watch"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "rspack",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^(ERROR|WARNING) in (.+)$",
            "severity": 1,
            "file": 2,
            "message": 0
          },
          {
            "regexp": "^\\s*(\\d+):(\\d+)\\s+(.+)$",
            "line": 1,
            "column": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*rspack build --mode development --watch.*",
          "endsPattern": ".*Rspack compiled.*"
        }
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
