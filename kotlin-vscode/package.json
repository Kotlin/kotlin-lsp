{
  "name": "kotlin-server",
  "displayName": "Kotlin by JetBrains",
  "version": "0.0.1",
  "description": "Language Support for Kotlin by JetBrains",
  "categories": [
    "Debuggers",
    "Formatters",
    "Linters",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "intellij",
    "jetbrains",
    "kotlin",
    "language server",
    "lsp"
  ],
  "bugs": "https://github.com/Kotlin/kotlin-lsp",
  "license": "SEE LICENSE IN LICENSE.txt",
  "author": "JetBrains",
  "repository": {
    "url": "https://github.com/Kotlin/kotlin-lsp",
    "directory": "kotlin-vscode"
  },
  "publisher": "JetBrains",
  "type": "module",
  "main": "./out/dist/extension.js",
  "scripts": {
    "compile": "rspack build --mode development",
    "watch": "rspack build --mode development --watch",
    "package": "rspack build --mode production --devtool hidden-source-map",
    "unpack-server": "node unpack-server.mjs",
    "test": "pnpm run test:grammar && pnpm run test:unit",
    "test:grammar": "textmate-grammar-snap --grammar syntaxes/kotlin.tmLanguage.json --scope source.kotlin \"testSources/tokenization/*.kt\"",
    "typecheck": "tsc --noEmit",
    "test:unit": "pnpm --filter @jetbrains/vscode-extension-core test && pnpm --filter @jetbrains/vscode-language-kotlin test",
    "updateGrammarTests": "textmate-grammar-snap --grammar syntaxes/kotlin.tmLanguage.json --scope source.kotlin -u \"testSources/tokenization/*.kt\""
  },
  "dependencies": {
    "@jetbrains/vscode-extension-core": "workspace:*",
    "@jetbrains/vscode-language-kotlin": "workspace:*",
    "@tree-sitter-grammars/tree-sitter-kotlin": "catalog:",
    "vscode-languageclient": "catalog:",
    "web-tree-sitter": "catalog:"
  },
  "devDependencies": {
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "@types/node": "catalog:",
    "@types/vscode": "catalog:",
    "@vscode/vsce": "catalog:",
    "textmate-grammar-test": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vscode-languageserver-types": "catalog:"
  },
  "contributes": {
    "languages": [
      {
        "id": "kotlin",
        "aliases": [
          "Kotlin",
          "kotlin"
        ],
        "extensions": [
          ".kt"
        ],
        "configuration": "./syntaxes/language-configuration-kotlin.json"
      }
    ],
    "grammars": [
      {
        "language": "kotlin",
        "scopeName": "source.kotlin",
        "path": "./syntaxes/kotlin.tmLanguage.json",
        "unbalancedBracketScopes": [
          "keyword.operator.kotlin"
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "kotlin"
      }
    ],
    "debuggers": [
      {
        "type": "intellij_debugger",
        "label": "IntelliJ Debugger",
        "languages": [
          "kotlin"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "mainClass"
            ],
            "properties": {
              "mainClass": {
                "type": "string",
                "description": "Fully-qualified name of the main class to run."
              },
              "file": {
                "type": "string",
                "description": "Path to the source file declaring the main class. Used to launch directly from a file, and to disambiguate when the main class name is declared in more than one file. Supports ${file}."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Program arguments passed to the main class."
              },
              "vmArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "JVM arguments."
              },
              "classPaths": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Override classpath. If empty, the LSP server resolves it from the project model."
              },
              "modulePaths": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Module path entries for JPMS launches. Specify manually; the LSP server does not resolve these automatically."
              },
              "javaExec": {
                "type": "string",
                "description": "Path to the java executable. If empty, the project SDK is used."
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the launched process.",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Extra environment variables for the launched process."
              }
            }
          },
          "attach": {
            "required": [
              "port"
            ],
            "properties": {
              "hostName": {
                "type": "string",
                "description": "Host the JVM is listening on.",
                "default": "localhost"
              },
              "port": {
                "type": "number",
                "description": "JDWP port the JVM is listening on.",
                "default": 5005
              },
              "timeout": {
                "type": "number",
                "description": "Connection timeout in milliseconds.",
                "default": 30000
              }
            }
          }
        },
        "initialConfigurations": [],
        "configurationSnippets": [
          {
            "label": "IntelliJ: Launch main class",
            "description": "Launch a JVM main class via the IntelliJ LSP.",
            "body": {
              "type": "intellij_debugger",
              "request": "launch",
              "name": "${2:Run main}",
              "mainClass": "${1:com.example.Main}",
              "cwd": "^\"\\${workspaceFolder}\""
            }
          },
          {
            "label": "IntelliJ: Attach to JVM",
            "description": "Attach to a running JVM over JDWP via the IntelliJ LSP.",
            "body": {
              "type": "intellij_debugger",
              "request": "attach",
              "name": "${1:Attach to JVM}",
              "hostName": "${2:localhost}",
              "port": 5005
            }
          }
        ]
      }
    ],
    "configuration": [
      {
        "title": "Kotlin by JetBrains",
        "properties": {
          "intellij.dev.serverPort": {
            "type": "number",
            "default": -1,
            "description": "Port for the locally started server to listen on. -1 to start the bundled server"
          },
          "intellij.dev.serverTimeoutMs": {
            "type": "number",
            "default": 10000,
            "description": "Timeout (ms) for connecting to the external dev server."
          },
          "intellij.dev.logLaunch": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug logging for the bundled server launcher (logs launcher output and env)"
          },
          "intellij.dev.commands": {
            "type": "boolean",
            "default": false,
            "description": "Expose developer-only commands."
          },
          "intellij.additionalJvmArgs": {
            "type": "array",
            "default": [],
            "description": "Additional JVM arguments to pass to the LSP server"
          },
          "intellij.buildTool": {
            "type": "string",
            "default": null,
            "description": "A build tool to use for a server, workspace, folder (null = any, \"\" = none)"
          },
          "intellij.projects": {
            "type": "array",
            "default": [],
            "description": "Externally configured projects to import. Each entry points to a project's build file or workspace root together with the build tool to use for it.",
            "items": {
              "type": "object",
              "required": [
                "type",
                "path"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Build tool / project type",
                  "enum": [
                    "gradle",
                    "maven",
                    "bazel",
                    "json"
                  ]
                },
                "path": {
                  "type": "string",
                  "description": "URI pointing to the project's build file or workspace root, e.g. \"file:///proj-dir/pom.xml\""
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "maven"
                      }
                    },
                    "required": [
                      "type"
                    ]
                  },
                  "then": {
                    "properties": {
                      "env": {
                        "type": "object",
                        "description": "Maven only: extra environment variables for the import process.",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "system-properties": {
                        "type": "object",
                        "description": "Maven only: JVM system properties for the import process.",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "java-home": {
                        "type": "string",
                        "description": "Maven only: path to the JDK home used to run the import."
                      }
                    }
                  },
                  "else": {
                    "properties": {
                      "env": false,
                      "system-properties": false,
                      "java-home": false
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "bazel"
                      }
                    },
                    "required": [
                      "type"
                    ]
                  },
                  "then": {
                    "properties": {
                      "project-path": {
                        "type": "string",
                        "description": "Bazel only: path to the Bazel project file, relative to the workspace root."
                      }
                    }
                  },
                  "else": {
                    "properties": {
                      "project-path": false
                    }
                  }
                }
              ]
            }
          },
          "intellij.jdkForSymbolResolution": {
            "type": "string",
            "default": null,
            "description": "Path of the JDK for symbol resolution"
          },
          "intellij.trace.server": {
            "scope": "window",
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "Traces the communication between VS Code and the language server."
          }
        }
      },
      {
        "title": "Data Sharing",
        "properties": {
          "intellij.dataSharing": {
            "type": "string",
            "enum": [
              "full",
              "anonymous",
              "none"
            ],
            "enumDescriptions": [
              "Send anonymous usage statistics and full error reports (including exception messages and attachments).",
              "Send anonymous usage statistics and anonymized error reports (messages and user data stripped).",
              "Do not send usage statistics or error reports."
            ],
            "default": "none",
            "markdownDescription": "Controls what diagnostic data the language server shares with JetBrains.\n\nThe following table outlines what is sent at each level:\n\n| | Usage Data | Errors | Error Details (non-anonymized) |\n| --- | :---: | :---: | :---: |\n| `full` | ✓ | ✓ | ✓ |\n| `anonymous` | ✓ | ✓ | – |\n| `none` | – | – | – |"
          }
        }
      },
      {
        "title": "Inlays",
        "properties": {
          "jetbrains.kotlin.hints.settings.types.property": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for property types"
          },
          "jetbrains.kotlin.hints.settings.types.variable": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for local variable types"
          },
          "jetbrains.kotlin.hints.type.function.return": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for function return types"
          },
          "jetbrains.kotlin.hints.type.function.parameter": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for function parameter types"
          },
          "jetbrains.kotlin.hints.settings.lambda.return": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for return expressions"
          },
          "jetbrains.kotlin.hints.lambda.receivers.parameters": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for implicit receivers and parameters"
          },
          "jetbrains.kotlin.hints.settings.value.ranges": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for ranges"
          },
          "jetbrains.kotlin.hints.value.kotlin.time": {
            "type": "boolean",
            "default": true,
            "description": "Show kotlin.time package warning inlay hints"
          },
          "jetbrains.kotlin.hints.parameters": {
            "type": "boolean",
            "default": true,
            "description": "Show parameter names"
          },
          "jetbrains.kotlin.hints.parameters.compiled": {
            "type": "boolean",
            "default": true,
            "description": "Show compiled parameter names"
          },
          "jetbrains.kotlin.hints.parameters.excluded": {
            "type": "boolean",
            "default": false,
            "description": "Show excluded parameter names"
          },
          "jetbrains.kotlin.hints.call.chains": {
            "type": "boolean",
            "default": false,
            "description": "Function return type in call chains"
          }
        }
      },
      {
        "title": "File Templates",
        "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md).",
        "properties": {
          "jetbrains.templates.kotlin.Class": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nclass ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.File": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\n|",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Interface": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\ninterface ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Data Class": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\ndata class ${NAME}(|)\n",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Enum": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nenum class ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Annotation": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nannotation class ${NAME}(|)",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Object": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nobject ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/kotlin-vscode/docs/file_templates.md)."
          }
        }
      }
    ],
    "configurationDefaults": {
      "[kotlin]": {
        "editor.autoIndent": "none",
        "editor.formatOnType": false
      }
    },
    "commands": [
      {
        "command": "jetbrains.exportWorkspaceToJson",
        "category": "Workspaces",
        "title": "Export workspace structure to JSON"
      },
      {
        "command": "jetbrains.kotlin.restartLsp",
        "category": "IntelliJ",
        "title": "Restart Language Server"
      },
      {
        "command": "jetbrains.kotlin.clearCachesAndRestartLsp",
        "category": "IntelliJ",
        "title": "Clear Caches and Restart Language Server"
      },
      {
        "command": "jetbrains.kotlin.reloadWorkspace",
        "category": "IntelliJ",
        "title": "Reload Workspace"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:jetbrains.activateLsp",
    "onLanguage:kotlin",
    "workspaceContains:*/build.gradle",
    "workspaceContains:*/build.gradle.kts",
    "workspaceContains:*/pom.xml",
    "workspaceContains:*/settings.gradle",
    "workspaceContains:*/settings.gradle.kts",
    "workspaceContains:build.gradle",
    "workspaceContains:build.gradle.kts",
    "workspaceContains:pom.xml",
    "workspaceContains:settings.gradle",
    "workspaceContains:settings.gradle.kts"
  ],
  "icon": "icons/kotlin.png",
  "engines": {
    "node": ">=22.20.0",
    "vscode": "^1.105.1"
  }
}
