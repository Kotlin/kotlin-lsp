{
  "name": "kotlin",
  "displayName": "Kotlin by JetBrains",
  "description": "Language Support for Kotlin by JetBrains",
  "author": "JetBrains",
  "publisher": "JetBrains",
  "bugs": "https://github.com/Kotlin/kotlin-lsp",
  "icon": "icons/kotlin.png",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "repository": {
    "url": "https://github.com/Kotlin/kotlin-lsp",
    "directory": "kotlin-vscode"
  },
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=22.20.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension",
  "activationEvents": [
    "onCommand:jetbrains.activateLsp",
    "onLanguage:kotlin"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kotlin",
        "aliases": [
          "Kotlin",
          "kotlin"
        ],
        "extensions": [
          ".kt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kotlin",
        "scopeName": "source.kotlin",
        "path": "./syntaxes/kotlin.tmLanguage.json",
        "unbalancedBracketScopes": [
          "keyword.operator.kotlin"
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "kotlin"
      }
    ],
    "debuggers": [
      {
        "type": "intellij_debugger",
        "label": "IntelliJ Debugger",
        "languages": [
          "kotlin"
        ],
        "configurationAttributes": {}
      }
    ],
    "configuration": [
      {
        "title": "IntelliJ Language Server",
        "properties": {
          "intellij.dev.serverPort": {
            "type": "number",
            "default": -1,
            "description": "Port for the locally started server to listen on. -1 to start the bundled server"
          },
          "intellij.dev.logLaunch": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug logging for the bundled server launcher (logs launcher output and env)"
          },
          "intellij.additionalJvmArgs": {
            "type": "array",
            "default": [],
            "description": "Additional JVM arguments to pass to the LSP server"
          },
          "intellij.buildTool": {
            "type": "string",
            "default": null,
            "description": "A build tool to use for a server, workspace, folder (null = any, \"\" = none)"
          },
          "intellij.jdkForSymbolResolution": {
            "type": "string",
            "default": null,
            "description": "Path of the JDK for symbol resolution"
          },
          "intellij.trace.server": {
            "scope": "window",
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "off",
            "description": "Traces the communication between VS Code and the language server."
          }
        }
      },
      {
        "title": "Inlay",
        "properties": {
          "jetbrains.kotlin.hints.settings.types.property": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for property types"
          },
          "jetbrains.kotlin.hints.settings.types.variable": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for local variable types"
          },
          "jetbrains.kotlin.hints.type.function.return": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for function return types"
          },
          "jetbrains.kotlin.hints.type.function.parameter": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for function parameter types"
          },
          "jetbrains.kotlin.hints.settings.lambda.return": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for return expressions"
          },
          "jetbrains.kotlin.hints.lambda.receivers.parameters": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for implicit receivers and parameters"
          },
          "jetbrains.kotlin.hints.settings.value.ranges": {
            "type": "boolean",
            "default": true,
            "description": "Show inlay hints for ranges"
          },
          "jetbrains.kotlin.hints.value.kotlin.time": {
            "type": "boolean",
            "default": true,
            "description": "Show kotlin.time package warning inlay hints"
          },
          "jetbrains.kotlin.hints.parameters": {
            "type": "boolean",
            "default": true,
            "description": "Show parameter names"
          },
          "jetbrains.kotlin.hints.parameters.compiled": {
            "type": "boolean",
            "default": true,
            "description": "Show compiled parameter names"
          },
          "jetbrains.kotlin.hints.parameters.excluded": {
            "type": "boolean",
            "default": false,
            "description": "Show excluded parameter names"
          },
          "jetbrains.kotlin.hints.call.chains": {
            "type": "boolean",
            "default": false,
            "description": "Function return type in call chains"
          }
        }
      },
      {
        "title": "File Templates",
        "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md).",
        "properties": {
          "jetbrains.templates.kotlin.Class": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nclass ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.File": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\n|",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Interface": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\ninterface ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Data Class": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\ndata class ${NAME}(|)\n",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Enum": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nenum class ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Annotation": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nannotation class ${NAME}(|)",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.kotlin.Object": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "#if (${PACKAGE_NAME} && ${PACKAGE_NAME} != \"\")package ${PACKAGE_NAME}\n\n#end\nobject ${NAME} {\n\t|\n}",
            "markdownDescription": "Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          },
          "jetbrains.templates.include.Copyright": {
            "type": "string",
            "editPresentation": "multilineText",
            "default": "",
            "markdownDescription": "Can be used in templates using `#parse(\"Copyright\")`. Please check [documentation](https://github.com/Kotlin/kotlin-lsp/blob/main/docs/file_templates.md)."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "jetbrains.exportWorkspaceToJson",
        "category": "Workspaces",
        "title": "Export workspace structure to JSON"
      },
      {
        "command": "jetbrains.kotlin.restartLsp",
        "category": "Kotlin",
        "title": "Restart LSP server"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "@types/vscode": "^1.96.0",
    "ts-loader": "^9.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vscode-tmgrammar-test": "^0.1.3",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@tree-sitter-grammars/tree-sitter-kotlin": "^1.1.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-sql": "^0.1.0",
    "vscode-languageclient": "9.0.1",
    "web-tree-sitter": "^0.26.8"
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "vscode:prepublish": "npm run package && npm run unpack-server",
    "package": "webpack --mode production --devtool hidden-source-map",
    "apply-intellij": "node apply-intellij.js",
    "unpack-server": "node unpack-server.js",
    "test": "npm run test:grammar && npm run test:unit",
    "test:grammar": "vscode-tmgrammar-snap --grammar syntaxes/kotlin.tmLanguage.json --scope source.kotlin testSources/tokenization/*.kt",
    "test:unit": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "updateGrammarTests": "vscode-tmgrammar-snap --grammar syntaxes/kotlin.tmLanguage.json --scope source.kotlin --updateSnapshot testSources/tokenization/*.kt"
  }
}
