<idea-plugin>
  <extensionPoints>
    <extensionPoint qualifiedName="ls.markdownDocProvider" beanClass="com.intellij.lang.LanguageExtensionPoint" dynamic="true">
      <with attribute="implementationClass" implements="com.jetbrains.ls.api.features.impl.common.hover.LSHoverProviderBase$LSMarkdownDocProvider"/>
    </extensionPoint>
    <extensionPoint qualifiedName="ls.completionItemKindProvider" beanClass="com.intellij.lang.LanguageExtensionPoint" dynamic="true">
      <with attribute="implementationClass" implements="com.jetbrains.ls.api.features.completion.LSCompletionItemKindProvider"/>
    </extensionPoint>
    <extensionPoint qualifiedName="com.intellij.customFoldingProvider" interface="com.intellij.lang.folding.CustomFoldingProvider" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceInterface="com.intellij.codeInsight.folding.JavaCodeFoldingSettings"
                        serviceImplementation="com.intellij.codeInsight.folding.impl.JavaCodeFoldingSettingsBase"/>
  </extensions>

  <extensions defaultExtensionNs="ls">
    <completionItemKindProvider language=""
                                implementationClass="com.jetbrains.ls.api.features.impl.common.completion.LSAnyCompletionItemKindProvider"/>
  </extensions>
</idea-plugin>