<idea-plugin>
  <extensionPoints>
    <extensionPoint qualifiedName="com.intellij.refactoring.moveClassHandler"
                    interface="com.intellij.refactoring.move.moveClassesOrPackages.MoveClassHandler" dynamic="true"/>
    <extensionPoint qualifiedName="com.intellij.refactoring.moveAllClassesInFileHandler"
                    interface="com.intellij.refactoring.move.moveClassesOrPackages.MoveAllClassesInFileHandler" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceInterface="com.intellij.codeInsight.folding.JavaCodeFoldingSettings"
                        serviceImplementation="com.intellij.codeInsight.folding.impl.JavaCodeFoldingSettingsBase"/>

    <findUsagesHandlerFactory implementation="com.intellij.find.findUsages.JavaFindUsagesHandlerFactory" id="java"
                              order="last, before default"/>
  </extensions>
  <extensions defaultExtensionNs="ls">
    <markdownDocProvider language="JAVA"
                         implementationClass="com.jetbrains.ls.api.features.impl.javaBase.LSJavaMarkdownDocProvider"/>

    <completionItemKindProvider language="JAVA"
                                implementationClass="com.jetbrains.ls.api.features.impl.javaBase.LSJavaCompletionItemKindProvider"/>
  </extensions>
</idea-plugin>